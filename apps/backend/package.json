{
  "name": "teamflow-backend",
  "version": "1.0.0",
  "description": "TeamFlow Backend API",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "NODE_ENV=development node --experimental-modules --watch src/index.js",
    "start": "NODE_ENV=production node src/index.js",
    "test": "NODE_ENV=test vitest",
    "db:migrate": "node src/database/migrate.js",
    "db:seed": "node src/database/seed.js",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "pgtools": "^0.3.2",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express-validator": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "vitest": "^1.1.0",
    "supertest": "^6.3.3"
  }
}
